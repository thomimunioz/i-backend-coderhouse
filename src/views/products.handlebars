<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/products">Mi Ecommerce</a>
        <div class="d-flex align-items-center">
            <span class="navbar-text me-3 text-white">
                Hola, <strong>{{user.email}}</strong> 
                <span class="badge {{#if isAdmin}}bg-warning text-dark{{else}}bg-secondary{{/if}} ms-1">{{user.role}}</span>
            </span>
            
            {{#unless isAdmin}} <a href="/cart" class="btn btn-outline-info btn-sm me-3 fw-semibold">
                🛒 Ver mi Carrito
            </a>
            {{/unless}}

            <form action="/api/sessions/logout" method="POST" class="m-0">
                <button class="btn btn-danger btn-sm">Salir</button>
            </form>
        </div>
    </div>
</nav>

<div class="container">
    {{#if isAdmin}}
    <div class="d-flex justify-content-end gap-2 mb-3">
        <a href="/admin/users" class="btn btn-primary fw-bold shadow-sm">
            👥 Gestión de Usuarios
        </a>
        <a href="/product/create" class="btn btn-success fw-bold shadow-sm">
            ➕ Crear Nuevo Producto
        </a>
    </div>
    {{/if}}

<div class="card shadow-sm mb-4 border-0 bg-light">
    <div class="card-body">
        <form action="/products" method="GET" class="row g-3 align-items-center">
            
            <div class="col-12 col-md-5">
                <label class="form-label fw-bold small text-muted">Buscar Categoría</label>
                <input type="text" name="query" class="form-control" placeholder="Ej: monitores, perifericos..." value="{{query}}">
            </div>
            
            <div class="col-12 col-md-4">
                <label class="form-label fw-bold small text-muted">Ordenar por Precio</label>
                <select name="sort" class="form-select">
                    <option value="">Sin orden</option>
                    <option value="asc">Más barato primero (asc)</option>
                    <option value="desc">Más caro primero (desc)</option>
                </select>
            </div>

            <div class="col-12 col-md-3 d-flex align-items-end gap-2 mt-md-4">
                <button type="submit" class="btn btn-primary w-100 fw-semibold">Buscar</button>
                <a href="/products" class="btn btn-outline-secondary w-100">Limpiar</a>
            </div>

        </form>
    </div>
</div>

<div class="container mb-5">
    <div class="row g-4"> 
        {{#each products}}
        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
            
            <div class="card h-100 shadow-sm border transition-hover">
                
                <div class="bg-light d-flex align-items-center justify-content-center rounded-top border-bottom" style="height: 220px;">
                    <span class="opacity-50" style="font-size: 4rem;">📦</span>
                </div>
                
                <div class="card-body d-flex flex-column">
                    <h6 class="card-subtitle text-muted mb-1 lh-base">{{this.title}}</h6>
                    
                    <h3 class="card-title mb-2 fw-bold text-dark">$ {{this.price}}</h3>
                    
                    <p class="card-text small text-secondary mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                        {{this.description}}
                    </p>
                    
                    <div class="mt-auto pt-2 border-top">
                        <div class="d-flex justify-content-between small text-muted mt-2">
                            <span><strong>Stock:</strong> {{this.stock}}</span>
                            <span><strong>Cod:</strong> {{this.code}}</span>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white border-0 pt-0 pb-3">
                    {{#if ../isAdmin}}
                        <a href="/products/{{this._id}}" class="btn btn-warning w-100 py-2 fw-semibold shadow-sm text-dark">
                        Editar Producto
                        </a>
                    {{else}}
                        <div class="d-flex gap-2">
                            <input type="number" id="qty-{{this._id}}" class="form-control text-center shadow-sm" value="1" min="1" max="{{this.stock}}" style="width: 80px;">
                            <button class="btn btn-primary w-100 fw-semibold shadow-sm" onclick="addQtyToCart('{{this._id}}', '{{../user.cartId}}')">
                                Agregar
                            </button>
                        </div>
                    {{/if}}
                </div>
            </div> 
        </div> 
        {{/each}}
    </div>
</div>

<div class="container d-flex justify-content-center align-items-center gap-4 mt-2 mb-5">
    
    {{#if hasPrevPage}}
        <a href="/products?page={{prevPage}}{{#if query}}&query={{query}}{{/if}}{{#if sort}}&sort={{sort}}{{/if}}" class="btn btn-primary fw-bold px-4 shadow-sm">
            &laquo; Anterior
        </a>
    {{else}}
        <button class="btn btn-secondary fw-bold px-4 shadow-sm" disabled>
            &laquo; Anterior
        </button>
    {{/if}}
    
    <span class="fs-5 fw-semibold text-secondary">
        Página <span class="badge bg-dark text-white mx-1">{{page}}</span> de {{totalPages}}
    </span>

    {{#if hasNextPage}}
        <a href="/products?page={{nextPage}}{{#if query}}&query={{query}}{{/if}}{{#if sort}}&sort={{sort}}{{/if}}" class="btn btn-primary fw-bold px-4 shadow-sm">
            Siguiente &raquo;
        </a>
    {{else}}
        <button class="btn btn-secondary fw-bold px-4 shadow-sm" disabled>
            Siguiente &raquo;
        </button>
    {{/if}}

</div>

<script>
    const addQtyToCart = async (pid, cid) => {
        const quantity = document.getElementById(`qty-${pid}`).value;

        try {
            const response = await fetch(`/api/carts/${cid}/products/${pid}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ quantity: Number(quantity) })
            });

            if(response.ok) {
                alert(`¡Agregaste ${quantity} ítem(s) al carrito! 🛒`);
            } else {
                alert("Hubo un error al agregar el producto.");
            }
        } catch (error) {
            console.error("Error:", error);
        }
    }
</script>